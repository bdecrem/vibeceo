{
  "_meta": {
    "name": "JT10",
    "description": "Lead/Bass Synth - 101-style monosynth with sub-oscillator and LFO",
    "version": "1.0",
    "units": {
      "0-100": "Knob position (like hardware)",
      "Hz": "Filter frequency",
      "choice": "Discrete option"
    }
  },
  "lead": {
    "level": { "unit": "dB", "min": -60, "max": 6, "default": 0, "hint": "output level" },

    "sawLevel": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "sawtooth oscillator level" },
    "pulseLevel": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "pulse oscillator level" },
    "pulseWidth": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "pulse width" },

    "subLevel": { "unit": "0-100", "min": 0, "max": 100, "default": 30, "hint": "sub oscillator level" },
    "subMode": { "unit": "choice", "options": [0, 1, 2], "default": 0, "hint": "sub mode: 0=off, 1=-1oct, 2=-2oct" },

    "cutoff": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "filter cutoff" },
    "resonance": { "unit": "0-100", "min": 0, "max": 100, "default": 30, "hint": "filter resonance" },
    "envMod": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "filter envelope depth" },
    "keyTrack": { "unit": "0-100", "min": 0, "max": 100, "default": 50, "hint": "keyboard tracking amount" },

    "attack": { "unit": "0-100", "min": 0, "max": 100, "default": 1, "hint": "amp envelope attack" },
    "decay": { "unit": "0-100", "min": 0, "max": 100, "default": 30, "hint": "amp envelope decay" },
    "sustain": { "unit": "0-100", "min": 0, "max": 100, "default": 70, "hint": "amp envelope sustain" },
    "release": { "unit": "0-100", "min": 0, "max": 100, "default": 30, "hint": "amp envelope release" },

    "filterAttack": { "unit": "0-100", "min": 0, "max": 100, "default": null, "hint": "filter envelope attack (null = follow amp)" },
    "filterDecay": { "unit": "0-100", "min": 0, "max": 100, "default": null, "hint": "filter envelope decay (null = follow amp)" },
    "filterSustain": { "unit": "0-100", "min": 0, "max": 100, "default": null, "hint": "filter envelope sustain (null = follow amp)" },
    "filterRelease": { "unit": "0-100", "min": 0, "max": 100, "default": null, "hint": "filter envelope release (null = follow amp)" },

    "lfoRate": { "unit": "0-100", "min": 0, "max": 100, "default": 30, "hint": "LFO rate" },
    "lfoWaveform": { "unit": "choice", "options": ["triangle", "square", "sh"], "default": "triangle", "hint": "LFO waveform" },
    "lfoToPitch": { "unit": "0-100", "min": 0, "max": 100, "default": 0, "hint": "LFO to pitch depth" },
    "lfoToFilter": { "unit": "0-100", "min": 0, "max": 100, "default": 0, "hint": "LFO to filter depth" },
    "lfoToPW": { "unit": "0-100", "min": 0, "max": 100, "default": 0, "hint": "LFO to pulse width depth" },

    "glideTime": { "unit": "0-100", "min": 0, "max": 100, "default": 5, "hint": "portamento/glide time" }
  }
}
